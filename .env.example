# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres URI for migrations (Settings → Database → Connection string → URI).
# Use port 5432 (session/direct), not the transaction pooler on 6543.
# Example:
# postgresql://postgres:<YOUR_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Required for: npm run db:apply:clients-view
DATABASE_URL=
