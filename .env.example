# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public base URL for invite/reset redirects (recommended).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Direct Postgres URI for migrations (Settings → Database → Connection string → URI).
# Use port 5432 (session/direct), not the transaction pooler on 6543.
# Example:
# postgresql://postgres:<YOUR_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Required for: npm run db:apply:clients-view
DATABASE_URL=

# Server-only: required for creating/listing users in /nustatymai/paskyros
SUPABASE_SERVICE_ROLE_KEY=

# --- Lost QA (Gmail ingest) — server-only ---
# Google Workspace service account JSON (full object) with domain-wide delegation.
# Gmail scope: https://www.googleapis.com/auth/gmail.readonly
GMAIL_SERVICE_ACCOUNT_JSON=

# Comma-separated company email domains for agent/internal classification (e.g. acme.com,acme.lt)
LOST_QA_COMPANY_EMAIL_DOMAINS=

# Pub/Sub push OIDC audience: full URL of POST /api/internal/gmail/pubsub (recommended in prod)
GMAIL_PUBSUB_AUDIENCE=

# Exact Gmail label name used to detect Lost cases (defaults to "Lost" if unset)
GMAIL_LOST_LABEL=Lost

# Internal cron-style routes (watch bootstrap, history sync, etc.): reuse CRON_SECRET
# CRON_SECRET=

# OpenAI (Lost QA Stage 4 — structured case analysis)
OPENAI_API_KEY=

